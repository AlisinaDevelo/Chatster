# Copy to .env and load with your process manager, or export manually.

# CHATSTER_HTTP_ADDR=:8080
# CHATSTER_DB_PATH=./chatster.db

# Optional built frontend directory. Set in the single-service Docker image.
# CHATSTER_STATIC_DIR=../frontend/build

# Comma-separated browser Origins for WebSocket upgrades (empty = allow all, dev only).
# CHATSTER_ALLOWED_ORIGINS=https://chat.example,https://admin.example

# Per-IP WebSocket upgrade rate limit (set to 0 to disable).
# CHATSTER_WS_UPGRADE_RPS=5
# CHATSTER_WS_UPGRADE_BURST=10

# Per-client chat message rate limit (set to 0 to disable).
# CHATSTER_MESSAGE_RPS=5
# CHATSTER_MESSAGE_BURST=10
